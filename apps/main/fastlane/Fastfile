  desc "Deploy iOS IPA to Firebase App Distribution - Sandbox"
  lane :upload_firebase_sandbox do |options|
    ipa_path = options[:binary_path]
    groups = options.fetch(:group, "ios-internal")
    testers = options.fetch(:testers, "")

    firebase_options = {
      app: ENV["FIREBASE_APP_ID_IOS_SANDBOX"] || "",
      groups: groups,
      testers: testers,
      release_notes_file: "release_notes_sandbox.txt",
      ipa_path: ipa_path
