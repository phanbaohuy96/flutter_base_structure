# =========================================================================
# Android Keystore Configuration
# =========================================================================
# Copy this file to `keystore.properties` (same directory) and fill in real
# values for each build variant. `keystore.properties` is gitignored.
#
# Generate a keystore per environment with ./create_keystore.sh and drop the
# resulting .jks into this `keystores/` folder before building release flavors.
# Debug builds use the Android SDK default keystore and ignore this file.
#
# Certificate validity: 8760 days (24 years)
# =========================================================================

# -------------------------------------------------------------------------
# DEVELOPMENT
# -------------------------------------------------------------------------
# Certificate DN: CN=Your Org, OU=ORG, O=ORG, L=City, ST=State, C=Country
DEV_STORE_FILE=../keystores/dev_keystore.jks
DEV_KEY_ALIAS=placeholder-value
DEV_STORE_PASSWORD=placeholder-value
DEV_KEY_PASSWORD=placeholder-value

# -------------------------------------------------------------------------
# STAGING
# -------------------------------------------------------------------------
# Certificate DN: CN=Your Org, OU=ORG, O=ORG, L=City, ST=State, C=Country
STAGING_STORE_FILE=../keystores/staging_keystore.jks
STAGING_KEY_ALIAS=placeholder-value
STAGING_STORE_PASSWORD=placeholder-value
STAGING_KEY_PASSWORD=placeholder-value

# -------------------------------------------------------------------------
# SANDBOX
# -------------------------------------------------------------------------
# Certificate DN: CN=Your Org, OU=ORG, O=ORG, L=City, ST=State, C=Country
SANDBOX_STORE_FILE=../keystores/sandbox_keystore.jks
SANDBOX_KEY_ALIAS=placeholder-value
SANDBOX_STORE_PASSWORD=placeholder-value
SANDBOX_KEY_PASSWORD=placeholder-value

# -------------------------------------------------------------------------
# PRODUCTION
# -------------------------------------------------------------------------
# Certificate DN: CN=Your Org, OU=ORG, O=ORG, L=City, ST=State, C=Country
PROD_STORE_FILE=../keystores/keystore.jks
PROD_KEY_ALIAS=placeholder-value
PROD_STORE_PASSWORD=placeholder-value
PROD_KEY_PASSWORD=placeholder-value
