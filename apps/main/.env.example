# Environment Configuration
#
# Copy this file to `.env` and fill in the values for your target environment.
# `.env` is gitignored; `.env.example` lives in the repo as the source of truth
# for what keys the app expects via --dart-define-from-file.

DART_ENV_NAME=''
DART_BASE_API_LAYER=''
DART_STORAGE_API_LAYER=''
DART_STORAGE_ASSET_LAYER=''
DART_PRIVACY_URL=''
DART_COOKIES_CONSENT_URL=''
DART_TERMS_URL=''

