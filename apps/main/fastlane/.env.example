# Firebase App Distribution
# * Required for Firebase deployment
FIREBASE_APP_ID_ANDROID_DEV=1:xxxxx:android:xxxxx
FIREBASE_APP_ID_ANDROID_STAGING=1:xxxxx:android:xxxxx
FIREBASE_APP_ID_ANDROID_SANDBOX=1:xxxxx:android:xxxxx
FIREBASE_APP_ID_ANDROID_PROD=1:xxxxx:android:xxxxx
FIREBASE_APP_ID_IOS_DEV=1:xxxxx:ios:xxxxx
FIREBASE_APP_ID_IOS_STAGING=1:xxxxx:ios:xxxxx
FIREBASE_APP_ID_IOS_SANDBOX=1:xxxxx:ios:xxxxx
FIREBASE_APP_ID_IOS_PROD=1:xxxxx:ios:xxxxx

# Firebase Authentication (choose ONE method)
# Method 1: Service Account (RECOMMENDED for CI/CD - never expires)
# * Download from Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
# * Base64 encode the JSON file: cat firebase-service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_JSON=base64_encoded_service_account_json

# Method 2: CLI Token (Alternative - may expire after 6 months inactivity)
# * Generate with: firebase login:ci
# * Use for local development or if service account is not available
FIREBASE_TOKEN=your_firebase_cli_token_here

# App Store Connect API (for TestFlight/App Store uploads)
# * Required only if using upload_testflight or deploy_app_store lanes
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_API_KEY_CONTENT=base64_encoded_p8_key_content
