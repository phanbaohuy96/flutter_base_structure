  desc "Deploy iOS IPA to Firebase App Distribution - Production"
  lane :upload_firebase_prod do |options|
    ipa_path = options[:binary_path]
    groups = options.fetch(:group, "ios-internal")
    testers = options.fetch(:testers, "")

    firebase_options = {
      app: ENV["FIREBASE_APP_ID_IOS_PROD"] || "",
      groups: groups,
      testers: testers,
      release_notes_file: "release_notes_prod.txt",
      ipa_path: ipa_path
    }
    
    # Service account takes precedence over CLI token (recommended for CI/CD)
    if ENV["FIREBASE_SERVICE_ACCOUNT_JSON"]
      service_account_path = "/tmp/firebase-service-account.json"
      File.write(service_account_path, Base64.decode64(ENV["FIREBASE_SERVICE_ACCOUNT_JSON"]))
      firebase_options[:service_credentials_file] = service_account_path
    elsif ENV["FIREBASE_TOKEN"]
      firebase_options[:firebase_cli_token] = ENV["FIREBASE_TOKEN"]
    end
    
    firebase_app_distribution(firebase_options)
  end

  desc "Upload to TestFlight"
  lane :upload_testflight do |options|
    ipa_path = options[:binary_path]
    
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )
    
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

  desc "Deploy to App Store"
  lane :deploy_app_store do |options|
    ipa_path = options[:binary_path]
    
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )
    
    upload_to_app_store(
      api_key: api_key,
      ipa: ipa_path,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: false
    )
  end
end

# Error handling
error do |lane, exception, options|
  UI.error("Error in lane #{lane}: #{exception.message}")
end
